{
  "name": "nvm-status-switch",
  "displayName": "NVM Status Switch",
  "description": "Automatically detects and switches Node.js versions",
  "version": "0.0.2",
  "publisher": "OwenLobatoV",
  "author": {
    "name": "OwenLobato"
  },
  "icon": "icon.png",
  "keywords": [
    "nvm",
    "node",
    "version",
    "nvmrc",
    "switch",
    "manager"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OwenLobato/vsc-extension-nvm-status.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/index.js",
  "contributes": {
    "commands": [
      {
        "command": "nvm-status-switch.showPicker",
        "title": "NVM Status Switch: Select Node Version",
        "icon": "$(versions)"
      },
      {
        "command": "nvm-status-switch.refreshUI",
        "title": "NVM Status Switch: Refresh Project Version",
        "icon": "$(refresh)"
      }
    ]
  },
  "pricing": "Free",
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
