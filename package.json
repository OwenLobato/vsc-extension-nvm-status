  "description": "Automatically detects .nvmrc and switches Node.js versions in your terminal",
  "version": "0.0.1",
  "publisher": "OwenLobatoV",
  "author": {
    "name": "OwenLobato"
  },
  "icon": "icon.png",
  "keywords": [
    "nvm",
    "node",
    "version",
    "nvmrc",
    "switch"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OwenLobato/vsc-extension-nvm-status.git"
  },
  "license": "MIT",
  "engines": {
